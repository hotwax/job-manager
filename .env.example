VITE_I18N_LOCALE=en-US
VITE_I18N_FALLBACK_LOCALE=en-US
VITE_CACHE_MAX_AGE=3600
VITE_VIEW_SIZE=10
VITE_APP_PERMISSION_ID="JOB_MANAGER_APP_VIEW"
VITE_ALIAS={"local":"http://localhost:8080"}
VITE_DEFAULT_ALIAS=local
VITE_OMS_TYPE=MOQUI
VITE_DEFAULT_LOG_LEVEL="error"
VITE_LAUNCHPAD_URL="http://launchpad.hotwax.io/login"
VITE_LEGACY_APP_URL="https://job-manager-legacy.hotwax.io/login?oms={oms}&token={token}&expirationTime={expirationTime}&omsRedirectionUrl={omsRedirectionUrl}"
VITE_PRT_STR_DEP_SER_JOB_IDENTIFIER=["productStoreIds", "productStoreId", "systemMessageRemoteId"]
VITE_MAARG_COMPATIBLE_VERSION="5.2.0"

# --- Fast Travel (Cmd/Ctrl+K app switcher) ---
# Base URLs of sibling HotWax admin apps (VITE_LAUNCHPAD_URL above is also used). Blank = that app
# shows as "Not configured" in the palette for this deployment.
VITE_JOB_MANAGER_URL=""
VITE_ORDER_MANAGER_URL=""
VITE_ORDER_ROUTING_URL=""
VITE_COMPANY_URL=""
VITE_PRODUCTS_URL=""
VITE_TRANSFERS_URL=""
VITE_CYCLE_COUNT_URL=""
